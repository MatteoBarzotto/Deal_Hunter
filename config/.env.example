# Allegro REST API (https://developer.allegro.pl/)
ALLEGRO_CLIENT_ID=your_allegro_client_id
ALLEGRO_CLIENT_SECRET=your_allegro_client_secret
# User-Agent MUST match registered app name exactly (case-sensitive).
# Find your app name at https://apps.developer.allegro.pl/
# Format: "AppName/Version (+https://info-url)"
ALLEGRO_USER_AGENT=DealHunter/0.1 (+https://github.com/your-user/deal-hunter)

# Azure OpenAI (deploy your GPT model in Azure AI Foundry first)
# Endpoint copied from the deployment page, looks like:
#   https://<resource-name>.openai.azure.com/
# Deployment name is whatever you named your model deployment.
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# Discord webhook (Server Settings -> Integrations -> Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Database (default: local SQLite file in project root)
DATABASE_URL=sqlite:///./deal_hunter.db

# Logging
LOG_LEVEL=INFO
